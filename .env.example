OPENAI_API_KEY=sk-...
# Public origin of this API (no trailing slash). Used for email preview & links — NOT a placeholder like api.example.com
# PUBLIC_APP_URL=https://api.din-egne-domæne.dk
# Trustpilot: pass ?domain=your-site.dk on GET /review for ratings 4–5 (see email template)
# PREVIEW_TRUSTPILOT_DOMAIN=jysk.dk
# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
# Server-side: use service_role key (keep secret; never expose to browsers)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Optional: negative reviews POST here (Slack Incoming Webhook URL)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Optional overrides
# OPENAI_MODEL=gpt-4o-mini
# HTTP port (default 3000 if unset)
PORT=3000
# GET /review: default is debug JSON (no redirect). Set 0 to restore redirects after verifying deploy.
# REVIEW_ROUTE_DEBUG=0
